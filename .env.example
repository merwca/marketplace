# Marketplace Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================

# Database URL - PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/marketplace

# JWT Secret for authentication tokens
# IMPORTANT: Generate a strong random secret for production
# Command: openssl rand -base64 32
JWT_SECRET=your-ultra-secret-jwt-key-change-in-production

# Node.js environment
# Options: development, staging, production
NODE_ENV=development

# Backend API port
BACKEND_PORT=4000

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# Frontend port
FRONTEND_PORT=3000

# API URL for frontend to communicate with backend
#
# Development (local):
#   NEXT_PUBLIC_API_URL=http://localhost:4000
#   (Frontend and backend on different ports)
#
# Production with reverse proxy:
#   NEXT_PUBLIC_API_URL=  (leave empty)
#   (Frontend and backend on same origin, proxy handles routing)
#
# Production with API on different domain:
#   NEXT_PUBLIC_API_URL=https://api.yourdomain.com
#   (Frontend and backend on different domains)
#
NEXT_PUBLIC_API_URL=http://localhost:4000

# ============================================================================
# DEPLOYMENT SCENARIOS
# ============================================================================

# Scenario 1: Local Development (Docker Compose)
# - Use default values above
# - Run: docker-compose up

# Scenario 2: Production with Reverse Proxy (Recommended)
# - Leave NEXT_PUBLIC_API_URL empty
# - Configure nginx/apache to route:
#   - /api/* -> backend:4000
#   - /* -> frontend:3000
# - Set JWT_SECRET to a strong random value
# - Set NODE_ENV=production

# Scenario 3: Production with Separate Domains
# - Set NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# - Ensure CORS is properly configured
# - Use HTTPS in production

# ============================================================================
# SECURITY NOTES
# ============================================================================
#
# NEVER commit .env with real secrets to version control!
# - Use .env.example for documentation only
# - Keep .env in .gitignore
# - In CI/CD, inject secrets as environment variables
# - Change JWT_SECRET for each environment
# - Use strong database passwords
# - Enable HTTPS in production
# - Configure CORS properly
#
